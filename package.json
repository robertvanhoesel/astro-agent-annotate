{
  "name": "astro-agent-annotate",
  "version": "0.0.1",
  "description": "Astro dev toolbar plugin: Alt+Click any element, annotate it, copy notes + source context to clipboard for AI agents.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/robertvanhoesel/astro-agent-annotate.git"
  },
  "homepage": "https://github.com/robertvanhoesel/astro-agent-annotate#readme",
  "bugs": {
    "url": "https://github.com/robertvanhoesel/astro-agent-annotate/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "demo.gif"
  ],
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "dev": "tsup --watch",
    "version-packages": "changeset version",
    "typecheck": "tsc --noEmit",
    "demo": "cd demo && pnpm dev"
  },
  "keywords": [
    "astro",
    "astro-integration",
    "dev-toolbar",
    "annotate",
    "ai-agent"
  ],
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.0.0",
    "astro": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.2"
  },
  "packageManager": "pnpm@10.12.1"
}
